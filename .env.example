# Copy this file to .env and fill in your key. .env is gitignored.
# Get a key at https://aistudio.google.com/apikey

GEMINI_API_KEY=

# Optional — override the image model ("Nano Banana" is the default).
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional — art aspect ratio. Defaults to 5:4 to match the card art slot.
# Supported: 1:1, 16:9, 9:16, 4:3, 3:2, 4:5, 5:4, 3:4, 21:9
# GEMINI_ASPECT_RATIO=5:4
